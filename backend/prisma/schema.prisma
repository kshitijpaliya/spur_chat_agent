generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Conversation {
  id         String @id @default(cuid())
  createdAt  DateTime @default(now())

  messages   Message[]
}

model Message {
  id             String @id @default(cuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  sender         Sender
  content        String

  createdAt      DateTime @default(now())
}

enum Sender {
  USER
  AI
}